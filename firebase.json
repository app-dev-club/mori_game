{
  "database": {
    "rules": "database.rules.json"
  },
  "functions": {
    "source": "functions",
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR\" ci",
      "npm --prefix \"$RESOURCE_DIR\" run build"
    ]
  },
  "hosting": {
    "public": "build/web",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "/(index.html|flutter_service_worker.js|flutter_bootstrap.js|main.dart.js|version.json)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ]
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "mori-game",
          "appId": "1:347939440644:android:347cba0d40e41a2c164d51",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "mori-game",
          "configurations": {
            "android": "1:347939440644:android:347cba0d40e41a2c164d51",
            "ios": "1:347939440644:ios:dd44bfc440971884164d51",
            "web": "1:347939440644:web:fa9fc6758e845668164d51"
          }
        }
      }
    }
  }
}
