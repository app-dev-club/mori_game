{
  "rules": {
    "rooms": {
      ".read": true,
      "$roomId": {
        ".read": true,
        ".write": "auth != null"
      }
    },
    "ratings": {
      ".read": "auth != null",
      "$playerId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['rating', 'mu', 'sigma', 'gamesPlayed']) && newData.child('rating').isNumber() && newData.child('mu').isNumber() && newData.child('sigma').isNumber() && newData.child('gamesPlayed').isNumber()"
      }
    },
    "users": {
      "$userId": {
        ".read": "auth != null && auth.uid == $userId",
        ".write": "auth != null && auth.uid == $userId",
        "playerName": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 12"
        },
        "morrieBalance": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        }
      }
    },
    "morrieRankings": {
      ".read": "auth != null",
      "$userId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['morrieBalance', 'playerName']) && newData.child('morrieBalance').isNumber() && newData.child('morrieBalance').val() >= 0 && newData.child('playerName').isString() && newData.child('playerName').val().length > 0 && newData.child('playerName').val().length <= 12"
      }
    },
    "matchRecords": {
      ".read": "auth != null",
      "$recordId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "matchRecordSummaries": {
      ".read": "auth != null",
      "$recordId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    }
  }
}
