{
  "rules": {
    "rooms": {
      ".read": true,
      "$roomId": {
        ".read": true,
        ".write": "auth != null && newData.exists()",
        "seriesRatingApplied": { ".write": false },
        "seriesRatingSummary": { ".write": false },
        "seriesRatingDetails": { ".write": false },
        "seriesMorrieSettled": { ".write": false },
        "seriesMorrieSummary": { ".write": false },
        "seriesMorrieDetails": { ".write": false },
        "settlementCompletedAt": { ".write": false },
        "settlementError": { ".write": false },
        "botMorrieBalances": { ".write": false },
        "morrieClaimed": {
          "$userId": {
            ".write": "auth != null && auth.uid == $userId"
          }
        }
      }
    },
    "ratings": {
      ".read": "auth != null",
      "$playerId": {
        ".write": false,
        "playerName": {
          ".write": "auth != null && auth.uid == $playerId"
        },
        "displayName": {
          ".write": "auth != null && auth.uid == $playerId"
        }
      }
    },
    "users": {
      "$userId": {
        ".read": "auth != null && auth.uid == $userId",
        ".write": false,
        "morrieBalance": {
          ".write": false
        },
        "playerName": {
          ".write": "auth != null && auth.uid == $userId",
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 12"
        },
        "updatedAt": {
          ".write": "auth != null && auth.uid == $userId"
        }
      }
    },
    "morrieRankings": {
      ".read": "auth != null",
      "$userId": {
        ".write": false
      }
    },
    "userMorriePending": {
      "$userId": {
        ".read": "auth != null && auth.uid == $userId",
        "$roomId": {
          ".write": "auth != null && auth.uid == $userId"
        }
      }
    },
    "matchRecords": {
      ".read": "auth != null",
      "$recordId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "matchRecordSummaries": {
      ".read": "auth != null",
      "$recordId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "appMeta": {
      ".read": true,
      ".write": false
    }
  }
}
