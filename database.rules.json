{
  "rules": {
    "rooms": {
      ".read": true,
      "$roomId": {
        ".read": true,
        ".write": "auth != null"
      }
    },
    "ratings": {
      ".read": "auth != null",
      "$playerId": {
        ".write": "auth != null",
        "rating": {
          ".validate": "newData.isNumber()"
        },
        "mu": {
          ".validate": "newData.isNumber()"
        },
        "sigma": {
          ".validate": "newData.isNumber()"
        },
        "gamesPlayed": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        }
      }
    },
    "users": {
      "$userId": {
        ".read": "auth != null && auth.uid == $userId",
        ".write": "auth != null && auth.uid == $userId",
        "morrieBalance": {
          ".write": "auth != null && newData.isNumber() && newData.val() >= 0"
        },
        "updatedAt": {
          ".write": "auth != null"
        },
        "playerName": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 12"
        }
      }
    },
    "morrieRankings": {
      ".read": "auth != null",
      "$userId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['morrieBalance', 'playerName']) && newData.child('morrieBalance').isNumber() && newData.child('morrieBalance').val() >= 0 && newData.child('playerName').isString() && newData.child('playerName').val().length > 0 && newData.child('playerName').val().length <= 12"
      }
    },
    "userMorriePending": {
      "$userId": {
        ".read": "auth != null && auth.uid == $userId",
        "$roomId": {
          ".write": "auth != null"
        }
      }
    },
    "matchRecords": {
      ".read": "auth != null",
      "$recordId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "matchRecordSummaries": {
      ".read": "auth != null",
      "$recordId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    }
  }
}
